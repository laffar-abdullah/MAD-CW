<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <!-- Header bar with app name and profile shortcut. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="BuyNGo Shop"
            android:textColor="@color/toolbar_text"
            android:textSize="18sp"
            android:textStyle="bold" />
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_myplaces"
            android:tint="@color/toolbar_text"
            android:contentDescription="Profile" />
    </RelativeLayout>

    <!-- Search field to help customers look up products quickly. -->
    <EditText
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:hint="Search products..."
        android:textSize="14sp"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_light"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/search_bg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/productContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <!-- Bottom navigation for cart, orders, reviews, and profile. -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/customer_bottom_menu"
        app:itemIconTint="@color/text_light"
        app:itemTextColor="@color/text_light" />

</LinearLayout>