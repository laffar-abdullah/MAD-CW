<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <!-- Checkout toolbar keeps the user oriented during the payment step. -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Checkout"
        app:titleTextColor="@color/toolbar_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Delivery details are collected before the final order confirmation. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivery Address"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_dark" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter your address"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/search_bg" />

            <!-- Customers pick how they want to pay here. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <!-- These radio buttons keep the payment choice easy and clear. -->
                <RadioGroup
                    android:id="@+id/paymentMethodGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RadioButton
                        android:id="@+id/radioCashOnDelivery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cash on Delivery"
                        android:textColor="@color/text_dark"
                        android:paddingVertical="6dp" />

                    <RadioButton
                        android:id="@+id/radioCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Credit/Debit Card"
                        android:textColor="@color/text_dark"
                        android:paddingVertical="6dp" />
                </RadioGroup>
            </androidx.cardview.widget.CardView>

            <!-- Demo card form only appears when card payment is selected. -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPaymentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Demo card payment instructions are shown here. -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Demo Card Payment"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use the sample details below to confirm the order"
                        android:textSize="12sp"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="4dp" />

                    <EditText
                        android:id="@+id/cardNumberInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:hint="Card Number"
                        android:inputType="number"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_light"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/search_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <EditText
                            android:id="@+id/cardExpiryInput"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="MM/YY"
                            android:inputType="text"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/search_bg" />

                        <EditText
                            android:id="@+id/cardCvvInput"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:hint="CVV"
                            android:inputType="numberPassword"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/search_bg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Demo: 4242 4242 4242 4242 | 12/28 | 123"
                        android:textSize="12sp"
                        android:textColor="@color/text_light"
                        android:layout_marginTop="10dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/placeOrderButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="Place Order"
        android:textColor="@color/white"
        android:background="@drawable/search_bg" />

</LinearLayout>
