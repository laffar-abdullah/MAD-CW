<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:title="Assign Rider"
        app:titleTextColor="@color/toolbar_text" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvOrderLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigning rider for:"
                android:textSize="12sp"
                android:textColor="@color/text_light" />

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #BNG-001"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green" />

            <TextView
                android:id="@+id/tvOrderCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer: Alice Smith"
                android:textSize="14sp"
                android:textColor="@color/text_dark" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:text="Select a rider:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/riderListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tvNoRiders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No riders registered yet. Go to Dashboard - Register Rider first."
        android:textSize="15sp"
        android:textColor="@color/text_light"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnConfirmAssign"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Confirm Assignment"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/search_bg" />

</LinearLayout>
