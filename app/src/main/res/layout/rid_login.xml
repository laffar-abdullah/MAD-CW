<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="@color/primary_green"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <ImageView
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/buyngologo"
        android:scaleType="fitCenter"
        android:contentDescription="BuyNGo Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Rider Login"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="32dp"
        android:text="View and update your delivery tasks"
        android:textSize="13sp"
        android:textColor="@color/text_light" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Rider ID / Email"
        android:textSize="14sp"
        android:textColor="@color/text_light" />

    <EditText
        android:id="@+id/riderEmailEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="textEmailAddress"
        android:hint="Enter rider email"
        android:textSize="15sp"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_light"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/search_bg" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Password"
        android:textSize="14sp"
        android:textColor="@color/text_light" />

    <EditText
        android:id="@+id/riderPasswordEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="textPassword"
        android:hint="Enter password"
        android:textSize="15sp"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_light"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/search_bg" />

    <Button
        android:id="@+id/riderLoginButton"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Login as Rider"
        android:textColor="@color/white"
        android:background="@color/primary_green" />

</LinearLayout>
