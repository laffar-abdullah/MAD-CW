<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:title="Add New Product"
        app:titleTextColor="@color/toolbar_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@color/white">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:alpha="0.4" />
                    <TextView
                        android:id="@+id/addImageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tap to add a photo"
                        android:textSize="14sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Product Name"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/inputProductName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textCapWords"
                android:hint="e.g. Fresh Apples"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Category"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/inputProductCategory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textCapWords"
                android:hint="e.g. Dairy, Bakery, Drinks"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Price ($)"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/inputProductPrice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="numberDecimal"
                android:hint="e.g. 2.99"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Stock Quantity"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/inputProductStock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:hint="e.g. 50"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Short Description"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/inputProductDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:hint="Describe the product..."
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/search_bg" />

            <Button
                android:id="@+id/btnSaveProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Product"
                android:textColor="@color/white"
                android:background="@drawable/search_bg" />

            <Button
                android:id="@+id/btnCancelProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="Cancel"
                android:textColor="@color/white"
                android:background="@drawable/search_bg" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
