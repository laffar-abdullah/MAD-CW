<?xml version="1.0" encoding="utf-8"?>
<!--
    rid_profile.xml

    ── WHAT'S ON THIS SCREEN ───────────────────────────────────────────────
    1. Toolbar          — "My Profile" title + back arrow
    2. Avatar banner    — profile photo, rider name, "Delivery Rider" tag
    3. Stats row        — Total Deliveries (from Firebase /orders)
                          Reviews Average  (from Firebase /reviews)
    4. Details card     — Full Name, Email, Phone, Vehicle
    5. Action buttons   — Log Out  |  Change Password
    6. Bottom nav bar   — Tasks / History / Reviews / Profile

    ── CHANGES (vs original) ────────────────────────────────────────────────
    • Added txtReviewsSummaryValue TextView in the stats row — bound in
      RidProfileActivity.loadReviewsSummary() via R.id.txtReviewsSummaryValue.
    • Gave each stat its own mini-card inside a horizontal stats row so the
      two numbers sit side-by-side cleanly.
    • Enhanced visual hierarchy: larger avatar, stronger stat labels.
    • All existing IDs kept identical — Java finds every view by the same ID.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="My Profile"
        app:titleTextColor="@color/toolbar_text"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Avatar banner ──────────────────────────────────────────── -->
            <!--
                Background matches toolbar so the banner looks like an
                extended header — a common Material pattern.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                android:background="@color/toolbar_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!--
                    imgProfilePicture — loaded by Glide in bindRiderData().
                    Tapping it launches the system photo picker.
                    ID: R.id.imgProfilePicture
                -->
                <ImageView
                    android:id="@+id/imgProfilePicture"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profile picture"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@color/primary_green_dark"
                    android:padding="2dp" />

                <!--
                    btnChangePhoto — also launches the photo picker.
                    ID: R.id.btnChangePhoto
                -->

                <!-- Rider's name — set in bindRiderData() from RiderSessionStore -->
                <TextView
                    android:id="@+id/txtProfileNameHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rider Name"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery Rider"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:paddingTop="2dp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════════════
                 STATS ROW — two mini-cards side by side
                 Left card:   Total Deliveries  (from Firebase /orders)
                 Right card:  Reviews average   (from Firebase /reviews)

                 Java wires these in:
                   loadDeliveryCount() → txtTotalDeliveriesValue
                   loadReviewsSummary() → txtReviewsSummaryValue
                 ══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <!-- DELIVERIES STAT CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <!-- Large number — e.g. "12 Deliveries"
                             Set by FirebaseRiderRepository.getDeliveredOrdersForRider()
                             called from loadDeliveryCount() in Java.          -->
                        <TextView
                            android:id="@+id/txtTotalDeliveriesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Deliveries"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Deliveries"
                            android:textSize="11sp"
                            android:textColor="@color/text_light"
                            android:paddingTop="4dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- REVIEWS STAT CARD — NEW -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <!--
                            Reviews summary — e.g. "4.5 ★  (8 reviews)"
                            Set by FirebaseRiderRepository.getReviewsForRider()
                            called from loadReviewsSummary() in Java.
                            ID: R.id.txtReviewsSummaryValue
                        -->
                        <TextView
                            android:id="@+id/txtReviewsSummaryValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No reviews yet"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/star_yellow" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer Reviews"
                            android:textSize="11sp"
                            android:textColor="@color/text_light"
                            android:paddingTop="4dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Details card ───────────────────────────────────────────── -->
            <!--
                Each field is a label + value pair separated by a divider.
                All values are set in bindRiderData() from RiderSessionStore.
            -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Full Name -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Full Name" android:textSize="11sp" android:textColor="@color/text_light"
                        android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/txtFullNameValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" android:paddingTop="2dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <!-- Email Address -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Email Address" android:textSize="11sp" android:textColor="@color/text_light"
                        android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/txtEmailValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" android:paddingTop="2dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <!-- Phone Number -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Phone Number" android:textSize="11sp" android:textColor="@color/text_light"
                        android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/txtPhoneValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" android:paddingTop="2dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <!-- Vehicle -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Vehicle" android:textSize="11sp" android:textColor="@color/text_light"
                        android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/txtVehicleValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Action buttons ─────────────────────────────────────────── -->
            <!--
                Log Out    — clears session, goes to AuthWelcomeActivity
                Change Password — opens showChangePasswordDialog() which calls
                                  FirebaseRiderRepository.changeRiderPassword()
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="#C0392B"
                    android:text="Log Out"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnChangePassword"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="#37474F"
                    android:text="Change Password"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom navigation bar ──────────────────────────────────────────── -->
    <!--
        Four tabs: Tasks / History / Reviews / Profile.
        Profile tab icon/text tinted green to indicate the active tab.
        Click listeners are set in Java.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">

        <LinearLayout android:id="@+id/navDashboard"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_today" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tasks" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navHistory"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navReviews"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/btn_star_big_on" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Reviews" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/primary_green" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="10sp"
                android:textColor="@color/primary_green" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>