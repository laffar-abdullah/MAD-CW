<?xml version="1.0" encoding="utf-8"?>
<!--
    rid_profile.xml

    ── CHANGES ──────────────────────────────────────────────────────────────
    1. imgProfilePicture — ImageView added inside the avatar banner so Glide
       can load the rider's saved photo into it. Tapping it opens the picker.

    2. btnChangePhoto — small button under the avatar for an explicit
       "Change Photo" affordance (also triggers the image picker in Java).

    3. btnChangePass → btnChangePassword — the critical ID fix.
       The Java file does:
           btnChangePassword = findViewById(R.id.btnChangePassword);
           btnChangePassword.setOnClickListener(v -> showChangePasswordDialog());
       The old layout had android:id="@+id/btnChangePass" — a mismatch that
       made btnChangePassword null at runtime, so clicking it caused a
       NullPointerException and nothing happened.
       Fixed by renaming to android:id="@+id/btnChangePassword".

    4. Logout and Change Password remain side-by-side in a horizontal row.
    ─────────────────────────────────────────────────────────────────────────
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="My Profile"
        app:titleTextColor="@color/toolbar_text"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Avatar banner ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="180dp"
                android:background="@color/toolbar_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="16dp">

                <!--
                    CHANGE 1: ImageView with id imgProfilePicture.
                    Java loads the rider's photo here via Glide.
                    Tapping it launches the same photo picker as btnChangePhoto.
                -->
                <ImageView
                    android:id="@+id/imgProfilePicture"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profile picture"
                    android:clickable="true"
                    android:focusable="true" />

                <!--
                    CHANGE 2: "Change Photo" button visible below the avatar.
                    ID must match Java: R.id.btnChangePhoto.
                -->
                <Button
                    android:id="@+id/btnChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="8dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Change Photo"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@color/primary_green_dark" />

                <TextView
                    android:id="@+id/txtProfileNameHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="James Rider"
                    android:textColor="@color/toolbar_text"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery Rider"
                    android:textColor="@color/toolbar_text"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- ── Details card ──────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Full Name" android:textSize="12sp" android:textColor="@color/text_light" />
                    <TextView
                        android:id="@+id/txtFullNameValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Email Address" android:textSize="12sp" android:textColor="@color/text_light" />
                    <TextView
                        android:id="@+id/txtEmailValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Phone Number" android:textSize="12sp" android:textColor="@color/text_light" />
                    <TextView
                        android:id="@+id/txtPhoneValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Vehicle" android:textSize="12sp" android:textColor="@color/text_light" />
                    <TextView
                        android:id="@+id/txtVehicleValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="15sp"
                        android:textColor="@color/text_dark" android:paddingBottom="14dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Deliveries" android:textSize="12sp" android:textColor="@color/text_light" />
                    <TextView
                        android:id="@+id/txtTotalDeliveriesValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 Deliveries" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/primary_green" android:paddingBottom="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!--
                ── Action buttons row ──────────────────────────────────────
                Both buttons share the full width equally via layout_weight="1".

                CHANGE 3: right button ID changed from btnChangePass to
                btnChangePassword — must match Java's:
                    btnChangePassword = findViewById(R.id.btnChangePassword)
                Without this the Java field is null and the click listener
                is never set, so the dialog never opens.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp"
                android:gravity="center_vertical">

                <!-- Deep red — signals a destructive / exit action -->
                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="#C0392B"
                    android:text="Log Out"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!--
                    CHANGE 3: was android:id="@+id/btnChangePass"
                    now  android:id="@+id/btnChangePassword"
                -->
                <Button
                    android:id="@+id/btnChangePassword"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="#37474F"
                    android:text="Change Password"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom navigation bar ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_today" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tasks" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReviews"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/btn_star_big_on" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Reviews" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/primary_green" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="10sp"
                android:textColor="@color/primary_green" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>