<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <!-- Feedback page toolbar with a close icon. -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Rate Your Order"
        app:titleTextColor="@color/toolbar_text"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Friendly icon and heading make the review page feel inviting. -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:src="@android:drawable/ic_menu_directions"
                android:contentDescription="Delivery" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="How was your delivery?"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Your feedback helps us improve"
                android:textSize="13sp"
                android:textColor="@color/text_light" />

            <!-- Star rating control for the customer’s quick score. -->
            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="1.0"
                android:progressTint="@color/primary_green"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/ratingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap a star to rate"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Write a review (optional)"
                android:textSize="14sp"
                android:textColor="@color/text_light" />

            <!-- Free-text review box for extra comments. -->
            <EditText
                android:id="@+id/reviewComment"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:hint="Share your experience..."
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:background="@drawable/search_bg" />

            <!-- Submit sends the customer back home after the review. -->
            <Button
                android:id="@+id/submitFeedbackButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Submit Review"
                android:textColor="@color/white"
                android:background="@drawable/search_bg" />
            <!-- Skip keeps the flow simple when the customer does not want to review. -->
            <TextView
                android:id="@+id/skipReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Skip for now"
                android:textColor="@color/text_light"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
