<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Rider Dashboard"
        app:titleTextColor="@color/toolbar_text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assigned Tasks"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:padding="16dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/sampleTaskCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Order #BNG-001" android:textSize="16sp"
                android:textStyle="bold" android:textColor="@color/text_dark" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Customer: Alice Johnson" android:textSize="13sp"
                android:textColor="@color/text_light" android:paddingTop="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Address: 12 Main Street, Springfield"
                android:textSize="13sp" android:textColor="@color/text_light" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Status: Out for Delivery" android:textSize="13sp"
                android:textColor="@color/primary_green" android:paddingTop="4dp" />
            <Button android:layout_width="match_parent" android:layout_height="44dp"
                android:layout_marginTop="12dp" android:text="Update Status"
                android:textColor="@color/white" android:background="@color/primary_green" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp">
        <Button
            android:id="@+id/btnMyReviews"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="My Reviews"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@color/primary_green" />
        <Button
            android:id="@+id/btnDeliveryHistory"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Delivery History"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@color/white" />
    </LinearLayout>

    <Button
        android:id="@+id/btnRiderProfile"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:text="My Profile"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:background="@color/primary_green" />

    <Button
        android:id="@+id/btnRiderLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:text="Log Out"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:background="#EF5350" />

</LinearLayout>