<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Rider Dashboard"
        app:titleTextColor="@color/toolbar_text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assigned Tasks"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:padding="16dp" />

    <TextView
        android:id="@+id/txtNoActiveTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No active tasks at the moment"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <androidx.cardview.widget.CardView
        android:id="@+id/sampleTaskCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <TextView
                android:id="@+id/txtTaskOrderId"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Order #BNG-001" android:textSize="16sp"
                android:textStyle="bold" android:textColor="@color/text_dark" />
            <TextView
                android:id="@+id/txtTaskCustomer"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Customer: Alice Johnson" android:textSize="13sp"
                android:textColor="@color/text_light" android:paddingTop="4dp" />
            <TextView
                android:id="@+id/txtTaskAddress"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Address: 12 Main Street, Springfield"
                android:textSize="13sp" android:textColor="@color/text_light" />
            <TextView
                android:id="@+id/txtTaskStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Status: Out for Delivery" android:textSize="13sp"
                android:textColor="@color/primary_green" android:paddingTop="4dp" />
            <Button
                android:id="@+id/btnTaskUpdateStatus"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:text="Update Status"
                android:textColor="@color/white"
                android:background="@color/primary_green" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">
        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/primary_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:textSize="10sp"
                android:textColor="@color/primary_green" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navReviews"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/btn_star_big_on" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reviews"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
