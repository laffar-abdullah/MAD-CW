<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="My Reviews"
        app:titleTextColor="@color/toolbar_text"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Order #BNG-001"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_dark" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5 stars" android:textSize="14sp"
                            android:textColor="@color/primary_green" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Customer: Alice Johnson" android:textSize="13sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Great delivery! Very fast and professional." android:textSize="13sp"
                        android:textColor="@color/text_dark" android:paddingTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="12 Feb 2026" android:textSize="11sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Order #BNG-003"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_dark" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4 stars" android:textSize="14sp"
                            android:textColor="@color/primary_green" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Customer: Bob Smith" android:textSize="13sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Package was delivered on time, good job." android:textSize="13sp"
                        android:textColor="@color/text_dark" android:paddingTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5 Feb 2026" android:textSize="11sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Order #BNG-005"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_dark" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5 stars" android:textSize="14sp"
                            android:textColor="@color/primary_green" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Customer: Carol White" android:textSize="13sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Excellent service! Will definitely order again." android:textSize="13sp"
                        android:textColor="@color/text_dark" android:paddingTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1 Feb 2026" android:textSize="11sp"
                        android:textColor="@color/text_light" android:paddingTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp">
        <Button
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Dashboard"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@color/primary_green" />
        <Button
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="History"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@color/primary_green" />
    </LinearLayout>

    <Button
        android:id="@+id/navProfile"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:text="Profile"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:background="@color/primary_green" />

</LinearLayout>