<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:title="Register New Rider"
        app:titleTextColor="@color/toolbar_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:text="Fill in the rider details below."
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/text_light" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Full Name"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etRiderName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPersonName"
                android:hint="Rider full name"
                android:imeOptions="actionNext"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Phone Number"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etRiderPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="phone"
                android:hint="e.g. 012-3456789"
                android:imeOptions="actionNext"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Vehicle Type"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etVehicleType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textCapWords"
                android:hint="e.g. Motorbike"
                android:imeOptions="actionNext"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Vehicle Number"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etVehicleNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textCapCharacters"
                android:hint="e.g. XYZ 4521"
                android:imeOptions="actionNext"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Login Email"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etRiderEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textEmailAddress"
                android:hint="rider@buyngo.com"
                android:imeOptions="actionNext"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Login Password"
                android:textSize="14sp"
                android:textColor="@color/text_light" />
            <EditText
                android:id="@+id/etRiderPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:hint="Set a password"
                android:imeOptions="actionDone"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/search_bg" />

            <Button
                android:id="@+id/btnRegisterRider"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Register Rider"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/search_bg" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
